# Copy to .env and adjust for your machine. .env is gitignored — never commit
# real values or absolute paths. config.py reads ONLY from here (see PLAN:
# "CPU -> GitHub -> GPU discipline"). No hardcoded paths anywhere else.

# --- Ollama / model ---------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
# CPU dev model (small, quantized). Swap UP on the A6000 with zero code change.
MODEL_NAME=qwen2.5:7b-instruct-q4_K_M
# GPU box example: MODEL_NAME=qwen2.5:32b-instruct-q4_K_M
EMBED_MODEL=bge-m3
# CPU dev can use a lighter/faster embedder (zero code change): nomic-embed-text

# --- Data roots (heavy + regenerable — keep OFF the code drive, not in the repo)
# These are a DATA_ROOT-style config: any disk works. D:\ is the Windows example
# (C: is small); on WSL/Linux use /mnt/d/... or any path (see the WSL block below).
DATA_DIR=D:\smart-mfg-agent\data
VECTORSTORE_DIR=D:\smart-mfg-agent\vectorstore
MEMORY_DIR=D:\smart-mfg-agent\memory
# WSL dev (mirrors the GPU box) needs Linux paths instead — D: is /mnt/d, e.g.:
#   DATA_DIR=/mnt/d/smart-mfg-agent/data
#   VECTORSTORE_DIR=/mnt/d/smart-mfg-agent/vectorstore
#   MEMORY_DIR=/mnt/d/smart-mfg-agent/memory

# --- Python agent service (FastAPI, :8000) ----------------------------------
AGENT_HOST=0.0.0.0
AGENT_PORT=8000

# --- Reproducibility --------------------------------------------------------
# Seed every random draw (synthetic data, detectors) so CPU and GPU runs match.
SEED=42
