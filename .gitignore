# --- Secrets / env ---
.env

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
*.egg-info/
build/
dist/

# --- Large / regenerable artifacts (these live on D:\ — never commit GBs) ---
# Datasets, vector store, and the memory store all sit under the D:\ roots
# named in .env. The local names below are a safety net in case anything
# regenerates inside the repo.
data/
vectorstore/
memory/
*.sqlite
*.sqlite3
*.jsonl
*.parquet
*.csv

# --- Ollama models / HF cache (on D:\ via OLLAMA_MODELS / HF_HOME) ---
.cache/
*.gguf

# --- Spring Boot / Java ---
ui-springboot/target/
ui-springboot/.gradle/
ui-springboot/build/
*.class

# --- IDE / OS ---
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db
